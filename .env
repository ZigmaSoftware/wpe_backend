# Set DEBUG=false for production
DEBUG=true
SECRET_KEY=A6MBSx4CfJtfvXV7Qh2yxKgp0dpj93ctJ8z0P1QDLCjKOHtcQcgC1tHjNvqpW_DyUFs

DB_NAME=wpe_db
DB_USER=root
DB_PASSWORD=admin@123
DB_HOST=127.0.0.1
DB_PORT=3306

ALLOWED_HOSTS=127.0.0.1,localhost,192.168.5.19,115.245.93.26
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://192.168.5.19:8080,http://115.245.93.26:8973
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://192.168.5.19:8080,http://115.245.93.26:8973

JWT_ACCESS_MINUTES=300
JWT_REFRESH_DAYS=7
INTERNAL_API_KEY=replace-with-shared-service-key
# Purpose: allow the local weight bridge to POST readings without a user login token.
# Keep this limited to /api/scale/ so normal API routes still require auth.
API_AUTH_EXEMPT_PATHS=/api/scale/,/api/weighscale/

GRN_SERVICE_BASE_URL=http://127.0.0.1:8002
GRN_SERVICE_API_KEY=replace-with-grn-api-key
DJANGO_TIME_ZONE=UTC
PRODUCTION_SCANCODE_TIME_ZONE=Asia/Kolkata

# Weight capture / Point Digi Scale indicator configuration.
# Purpose: enables/disables the backend scale endpoint and serial probing fallback.
SCALE_ENABLED=true

# Purpose: backend URL where scale-bridge posts readings. Change IP/port to the running Django backend.
# WPE_SERVER_URL=http://127.0.0.1:8000
WPE_SERVER_URL=http://192.168.1.128:7904


# Purpose: shared secret checked by backend and sent by scale-bridge. Keep one value here only.
SCALE_BRIDGE_API_KEY=wpe-bridge-api-key-123

# Purpose: unique weighing scale ID shown in frontend scale selection and saved with captures.
DEVICE_ID=AD-WEIGH-01

# Purpose: identifies the operator PC connected to the weighing indicator.
WORKSTATION_ID=PRODUCTION-PC-01

# Purpose: serial port connected to the indicator. AUTO scans ports; Windows example COM4; Linux example /dev/ttyUSB0.
SERIAL_PORT=AUTO

# Purpose: indicator serial speed. Keep 9600 unless the indicator manual uses a different baud rate.
SERIAL_BAUD_RATE=9600

# Purpose: how often scale-bridge pushes the latest reading to backend, in milliseconds.
PUSH_INTERVAL_MS=500

# Purpose: bridge marks reading stale if no valid serial data arrives within this many seconds.
STALE_AFTER_SECONDS=5

# Purpose: backend marks a bridge device offline if no push is received within this many seconds.
SCALE_BRIDGE_STALE_AFTER_SECONDS=5

# Production backend runs on port 7904
# Production frontend runs on port 8973
